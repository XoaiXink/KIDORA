@model IEnumerable<KIDORA.Data.KhachHang>

@{
    ViewData["Title"] = "Quản lý khách hàng";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}
<ol class="breadcrumb">
    <li class="breadcrumb-item">
        <a asp-area="Admin" asp-controller="Home" asp-action="Index">
            <i class="anticon anticon-home m-r-5"></i>Home
        </a>
    </li>
    <li class="breadcrumb-item active">Danh sách khách hàng</li>
</ol>

<h2 class="mb-4">Quản lý khách hàng</h2>

<div class="d-flex justify-content-between align-items-center mb-4">
    <!-- Ô tìm kiếm bên trái -->
    <form asp-action="Index" method="get" class="d-flex gap-2">
        <input type="text"
               name="keyword"
               class="form-control"
               placeholder="Tìm theo tên hoặc email..."
               style="max-width: 260px;" />

        <button type="submit"
                class="btn btn-primary text-nowrap">
            Tìm kiếm
        </button>
    </form>

    <!-- Nút thêm khách hàng bên phải -->
    <a asp-action="Create"
       class="btn btn-success text-nowrap px-3">
        + Thêm khách hàng mới
    </a>
</div>


<table class="table table-striped table-hover align-middle">
    <thead class="table-light">
        <tr>
            <th>Mã KH</th>
            <th>Họ tên</th>
            <th>Email</th>
            <th>Điện thoại</th>
            <th>Giới tính</th>
            <th>Ngày sinh</th>
            <th>Hạng</th>
            <th>K-Coin</th>
            <th>Ngày tham gia</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.MaKh</td>
                <td>@item.HoTen</td>
                <td>@item.Email</td>
                <td>@item.DienThoai</td>
                <td>@item.GioiTinh</td>
                <td>@item.NgaySinh?.ToString("dd/MM/yyyy")</td>
                <td>@item.MaHangNavigation?.TenHang</td>
                <td>@item.SoDuKcoin.ToString("N0")</td>
                <td>@item.NgayThamGia.ToString("dd/MM/yyyy")</td>
                <td class="text-end">
                    <a asp-action="Details" asp-route-id="@item.MaKh" class="btn btn-sm btn-info">Chi tiết</a>
                    <a asp-action="Edit" asp-route-id="@item.MaKh" class="btn btn-sm btn-warning">Sửa</a>
                    <a asp-action="Delete" asp-route-id="@item.MaKh" class="btn btn-sm btn-danger">Xóa</a>
                </td>
            </tr>
        }
    </tbody>
</table>

@if (!Model.Any())
{
    <div class="alert alert-secondary text-center mt-4">
        Chưa có khách hàng nào được ghi nhận.
    </div>
}


