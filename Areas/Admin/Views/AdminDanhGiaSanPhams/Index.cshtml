@model IEnumerable<KIDORA.Data.DanhGiaSanPham>

@{
    ViewData["Title"] = "Đánh giá của khách hàng";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<h2 class="mb-4">Đánh giá của khách hàng</h2>

<div class="mb-4">
    <form asp-action="Index" method="get" class="filter-bar d-flex align-items-center flex-wrap gap-2">

        <div style="flex: 1 1 350px; max-width: 380px;">
            <input type="text" name="searchString" class="form-control filter-input"
                   placeholder="Tìm theo mã KH, tên KH hoặc tên sản phẩm" />
        </div>

        <div style="width: 150px;">
            <select name="rating" class="form-select filter-input">
                <option value="">Tất cả số sao</option>
                <option value="5">5 sao</option>
                <option value="4">4 sao</option>
                <option value="3">3 sao</option>
                <option value="2">2 sao</option>
                <option value="1">1 sao</option>
            </select>
        </div>

        <div style="width: 170px;">
            <select name="status" class="form-select filter-input">
                <option value="all">Tất cả trạng thái</option>
                <option value="Pending">Pending</option>
                <option value="Approved">Approved</option>
                <option value="Rejected">Rejected</option>
            </select>
        </div>

        <div>
            <button type="submit" class="btn btn-primary filter-button px-4">
                Lọc
            </button>
        </div>
    </form>
</div>



<!-- Bảng đánh giá -->
<div class="card">
    <div class="card-body">
        <table class="table table-striped table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Mã ĐG</th>
                    <th>Sản phẩm</th>
                    <th>Khách hàng</th>
                    <th>Điểm</th>
                    <th>Nội dung</th>
                    <th>Ngày đánh giá</th>
                    <th>Trạng thái</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    string shortContent = item.NoiDung ?? "";
                    if (shortContent.Length > 80) shortContent = shortContent.Substring(0, 80) + "...";

                    string statusClass = item.TrangThai switch
                    {
                        "Approved" => "badge bg-success",
                        "Rejected" => "badge bg-danger",
                        "Pending" => "badge bg-warning text-dark",
                        _ => "badge bg-secondary"
                    };

                    <tr>
                        <td>@item.MaDanhGia</td>
                        <td>
                            <div class="fw-semibold">@item.MaSpNavigation?.TenSp</div>
                            <small class="text-muted">Mã SP: @item.MaSp</small>
                        </td>
                        <td>
                            <div class="fw-semibold">@item.MaKhNavigation?.HoTen</div>
                            <small class="text-muted">Mã KH: @item.MaKh</small>
                        </td>
                        <td>
                            @item.DiemDanhGia / 5
                        </td>
                        <td>@shortContent</td>
                        <td>@item.NgayDanhGia.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>
                            <span class="@statusClass">@item.TrangThai</span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        @if (!Model.Any())
        {
            <div class="alert alert-secondary text-center mt-3 mb-0">
                Chưa có đánh giá nào.
            </div>
        }
    </div>
</div>
