@model IEnumerable<KIDORA.Data.GdKcoin>

@{
    ViewData["Title"] = "Giao dịch K-Coin";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<h2 class="mb-4">Giao dịch K-Coin</h2>

<div class="mb-3 d-flex justify-content-between align-items-center">
    <form asp-action="Index" method="get" class="d-flex">
        <input type="text" name="searchString" class="form-control me-2" placeholder="Tìm theo tên hoặc mã khách hàng" />
        <select name="kieuGD" class="form-select me-2" style="width:150px">
            <option value="all">Tất cả</option>
            <option value="earn">Hoàn (Earn)</option>
            <option value="spend">Tiêu (Spend)</option>
            <option value="adjust">Điều chỉnh</option>
        </select>
        <button type="submit" class="btn btn-primary">Lọc</button>
    </form>
</div>

<div class="card">
    <div class="card-body">
        <table class="table table-striped table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Thời gian</th>
                    <th>Mã KH</th>
                    <th>Khách hàng</th>
                    <th>Loại GD</th>
                    <th>Số K-Coin</th>
                    <th>Số dư sau GD</th>
                    <th>Mã đơn hàng</th>
                    <th>Mô tả</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    string color = item.KieuGd == "earn" ? "text-success"
                    : item.KieuGd == "spend" ? "text-danger"
                    : "text-warning";

                    <tr>
                        <td>@item.ThoiGianGd.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>@item.MaKh</td>
                        <td>@item.MaKhNavigation?.HoTen</td>
                        <td class="@color text-capitalize">@item.KieuGd</td>
                        <td class="@color fw-bold">
                            @(item.KieuGd == "spend" ? "-" : "+")@item.SoKcoin
                        </td>
                        <td>@item.SoDuSauGd</td>
                        <td>@item.MaDonHang ?? "-"</td>
                        <td>@item.MoTa</td>
                    </tr>
                }
            </tbody>
        </table>

        @if (!Model.Any())
        {
            <div class="alert alert-secondary text-center mt-3 mb-0">
                Chưa có giao dịch K-Coin nào.
            </div>
        }
    </div>
</div>
